<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.innocence.server.modules.plan.mapper.StudyPlanMapper">

    <resultMap id="DailyPlanResultMap" type="com.innocence.server.modules.plan.domain.DailyPlan">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="planDate" column="plan_date"/>
        <result property="planName" column="plan_name"/>
        <result property="planType" column="plan_type"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <resultMap id="DailyPlanItemResultMap" type="com.innocence.server.modules.plan.domain.DailyPlanItem">
        <id property="id" column="id"/>
        <result property="planId" column="plan_id"/>
        <result property="userId" column="user_id"/>
        <result property="title" column="title"/>
        <result property="status" column="status"/>
        <result property="plannedMinutes" column="planned_minutes"/>
        <result property="actualMinutes" column="actual_minutes"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findDailyPlanByUserIdAndDate" resultMap="DailyPlanResultMap">
        select *
        from daily_plan
        where user_id = #{userId}
          and plan_date = #{planDate}
        limit 1
    </select>

    <select id="findDailyPlanItemsByPlanId" resultMap="DailyPlanItemResultMap">
        select *
        from daily_plan_item
        where plan_id = #{planId}
        order by sort_order asc, id asc
    </select>

    <insert id="insertDailyPlan" useGeneratedKeys="true" keyProperty="id">
        insert into daily_plan (user_id, plan_date, plan_name, plan_type)
        values (#{userId}, #{planDate}, #{planName}, #{planType})
    </insert>

    <update id="updateDailyPlan">
        update daily_plan
        set plan_name = #{planName},
            plan_type = #{planType}
        where id = #{id}
          and user_id = #{userId}
    </update>

    <delete id="deleteDailyPlanById">
        delete
        from daily_plan
        where id = #{planId}
    </delete>

    <delete id="deleteDailyPlanItemsByPlanId">
        delete
        from daily_plan_item
        where plan_id = #{planId}
    </delete>

    <insert id="insertDailyPlanItem" useGeneratedKeys="true" keyProperty="id">
        insert into daily_plan_item (plan_id, user_id, title, status, planned_minutes, actual_minutes, sort_order)
        values (#{planId}, #{userId}, #{title}, #{status}, #{plannedMinutes}, #{actualMinutes}, #{sortOrder})
    </insert>

</mapper>
